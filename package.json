{
  "name": "pi-academic-research-ieee",
  "version": "0.1.0",
  "private": true,
  "description": "IEEE-first academic research and manuscript workflow package for Pi, inspired by academic-research-skills and nature-skills.",
  "license": "CC-BY-NC-4.0",
  "keywords": [
    "pi-package",
    "pi",
    "agent-skills",
    "academic-writing",
    "ieee",
    "research"
  ],
  "type": "module",
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {},
  "scripts": {
    "test": "node scripts/smoke-extension.mjs && node scripts/lint-skill-metadata.mjs",
    "check:skills": "find skills -name SKILL.md -maxdepth 3 -print",
    "lint:skills": "node scripts/lint-skill-metadata.mjs",
    "pack:dry-run": "npm pack --dry-run"
  }
}
